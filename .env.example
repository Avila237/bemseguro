# Railway
PORT=8080
RAILWAY_SECRET_TOKEN=

# Aggilizador
AGGER_LOGIN=
AGGER_SENHA=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=
# Opcional: modelo de visao p/ a extracao de documentos (/extract).
# Default do wrapper se ausente: claude-sonnet-4-5
