# Railway
PORT=8080
RAILWAY_SECRET_TOKEN=
# Opcional: URL-base do auto-disparo do worker (/api/v1/cotacoes-com-docs).
# Vazio = http://127.0.0.1:$PORT (chamada local — caso normal no Railway).
RAILWAY_URL=

# Aggilizador
AGGER_LOGIN=
AGGER_SENHA=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=
# Opcional: modelo de visao p/ a extracao de documentos (/extract).
# Default do wrapper se ausente: claude-sonnet-4-5
ANTHROPIC_MODEL=

# Sentry (monitoring de erros). Vazio = Sentry desativado.
SENTRY_DSN=

# Ambiente
NODE_ENV=production
LOG_LEVEL=info
