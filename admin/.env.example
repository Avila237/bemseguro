# Variaveis do painel admin (Vite). Prefixo VITE_ e obrigatorio para
# que sejam expostas ao browser. Use sempre a ANON KEY (publica) aqui.
# Nenhum segredo do backend (ex: token do Railway) deve ficar aqui — o lookup
# de placa passa pela Edge Function lookup-placa do Supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
